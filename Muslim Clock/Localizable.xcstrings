    "— %@" : {

    },
    "· météo et audio en cache" : {

    },
    "« %@ »" : {

    },
    "« La Salât est le pilier de la religion »" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الصلاة عماد الدين"
          }
        }
      }
    },
    "« Notre Seigneur descend chaque nuit vers le ciel le plus bas lorsqu'il ne reste que le dernier tiers... » (Bukhari)" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"ينزل ربنا تبارك وتعالى كل ليلة إلى السماء الدنيا حين يبقى ثلث الليل الآخر...\" (رواه البخاري)"
          }
        }
      }
    },
    "%@ → %@" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ → %2$@"
          }
        }
      }
    },
    "%lld" : {

    },
