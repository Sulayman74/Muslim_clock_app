          "stringUnit" : {
            "state" : "translated",
            "value" : "!اكتملت السلسلة 🎉"
          }
        }
      }
    },
    "1. Maintenez votre doigt enfoncé sur un espace vide de votre écran d'accueil iPhone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "١. اضغط مطولاً على مساحة فارغة في شاشة الآيفون الرئيسية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Long press on an empty space on your iPhone home screen."
          }
        }
      }
    },
    "1er Quartier" : {

    },
    "2 Rak'at après l'Isha, puis clôturez par le Witr." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ركعتان بعد العشاء، ثم اختم بالوتر."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2 Rak'at after Isha, then close with Witr."
          }
        }
      }
    },
    "2 Rak'at après l'obligatoire." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ركعتان بعد الفريضة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2 Rak'at after the obligatory prayer."
          }
        }
      }
    },
    "2 Rak'at très méritoires avant l'obligatoire." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ركعتان مستحبتان قبل الفريضة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2 highly meritorious Rak'at before the obligatory prayer."
          }
        }
      }
    },
    "2. Touchez le bouton '+' en haut à gauche." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "٢. اضغط على زر '+' في أعلى اليسار."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. Tap the '+' button in the top left."
          }
        }
      }
    },
    "3. Cherchez 'Muslim Clock' dans la liste." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "٣. ابحث عن 'Muslim Clock' في القائمة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. Search for 'Muslim Clock' in the list."
          }
        }
